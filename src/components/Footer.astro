---
import { Image } from "astro:assets";
import { allCalculators } from "../utils/calculators";
import categoriesData from "../data/categories.json";
import LogoHorizontal from "../../public/images/logos/logo-horizontal.svg";

const totalCalculators = allCalculators.length;
const currentYear = new Date().getFullYear();

const footerLinks = {
  company: [
    { name: "About Us", href: "/about" },
    { name: "Contact", href: "/contact" },
    { name: "Privacy Policy", href: "/privacy" },
    { name: "Terms of Service", href: "/terms" },
  ],
  resources: [
    { name: "Blog", href: "/blog" },
    { name: "Newsletter", href: "/newsletter" },
    { name: "FAQ", href: "/faq" },
    { name: "Sitemap", href: "/sitemap-index.xml" },
  ],
};
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <!-- Logo & Description -->
      <div class="footer-section footer-brand">
        <Image
          src={LogoHorizontal}
          alt="CalcCrunch"
          class="footer-logo"
          format="webp"
          loading="eager"
        />
        <p class="footer-tagline">Crunch Your Numbers, Not Your Time</p>
        <p class="footer-description">
          Free online calculators for financial planning, health tracking, home
          projects, and everyday decisions.
        </p>
        <!-- <form
          class="footer-newsletter"
          action="https://assets.mailerlite.com/jsonp/2401361/forms/189197513738159323/subscribe"
          method="POST"
          data-newsletter-form
        >
          <p class="footer-newsletter-label">Get weekly tips:</p>
          <div class="footer-newsletter-group">
            <input
              type="email"
              name="fields[email]"
              placeholder="your@email.com"
              required
              class="footer-newsletter-input"
              aria-label="Email for newsletter"
            />
            <button type="submit" class="footer-newsletter-btn"
              >Subscribe</button
            >
          </div>
        </form> -->
      </div>

      <!-- Calculators Links -->
      <div class="footer-section">
        <h4>Calculators</h4>
        <ul class="footer-links">
          {
            categoriesData.categories
              ?.filter((cat) => cat?.featured && cat.calculatorCount >= 1)
              ?.sort((a, b) => b.calculatorCount - a.calculatorCount)
              ?.slice(0, 3)
              ?.map((cat) => (
                <li>
                  <a href={`/categories/${cat.slug}`}>{cat.name}</a>
                </li>
              ))
          }
          <li>
            <a href="/calculators">All Calculators ({totalCalculators})</a>
          </li>
        </ul>
      </div>

      <!-- Company Links -->
      {
        footerLinks?.company?.length ? (
          <div class="footer-section">
            <h4>Company</h4>
            <ul class="footer-links">
              {footerLinks?.company?.map((link) => (
                <li>
                  <a href={link.href}>{link.name}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : (
          ""
        )
      }

      <!-- Resources Links -->
      {
        footerLinks?.resources?.length ? (
          <div class="footer-section">
            <h4>Resources</h4>
            <ul class="footer-links">
              {footerLinks?.resources?.map((link) => (
                <li>
                  <a href={link.href}>{link.name}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : (
          ""
        )
      }
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} CalcCrunch. All rights reserved.
      </p>
      <p class="disclaimer">
        Calculators provided for informational purposes only. Consult
        professionals for financial, medical, or legal advice.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer-bg);
    color: #ffffff;
    padding: var(--space-3xl) 0 var(--space-xl);
    margin-top: var(--space-3xl);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .footer-brand {
    max-width: 350px;
  }

  .footer-logo {
    height: 50px;
    width: auto;
    margin-bottom: var(--space-md);
  }

  .footer-tagline {
    font-family: var(--font-primary);
    font-weight: 600;
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
  }

  .footer-description {
    opacity: 0.8;
    line-height: 1.6;
  }

  .footer-newsletter {
    margin-top: var(--space-lg);
  }

  .footer-newsletter-label {
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-sm);
    opacity: 0.9;
  }

  .footer-newsletter-group {
    display: flex;
    gap: var(--space-xs);
  }

  .footer-newsletter-input {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--border-radius);
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    font-size: var(--text-sm);
    font-family: var(--font-body);
  }

  .footer-newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent-orange);
    background: rgba(255, 255, 255, 0.15);
  }

  .footer-newsletter-btn {
    padding: var(--space-sm) var(--space-md);
    background: var(--color-accent-orange);
    color: #ffffff;
    border: none;
    border-radius: var(--border-radius);
    font-weight: 600;
    font-size: var(--text-sm);
    cursor: pointer;
    transition: background var(--transition-fast);
    white-space: nowrap;
  }

  .footer-newsletter-btn:hover {
    background: var(--color-accent-orange-dark, #e55a2b);
  }

  .footer-section h4 {
    color: #ffffff;
    font-family: var(--font-primary);
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: var(--space-sm);
  }

  .footer-links a {
    color: #ffffff;
    opacity: 0.8;
    transition: opacity var(--transition-fast);
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--color-accent-orange);
  }

  .footer-bottom {
    text-align: center;
    opacity: 0.7;
  }

  .copyright {
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .disclaimer {
    font-size: var(--text-sm);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (max-width: 968px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .footer-content {
      grid-template-columns: 1fr;
    }

    .footer-newsletter-group {
      flex-direction: column;
    }
  }
</style>

<script>
  document.querySelectorAll(".footer-newsletter").forEach((form) => {
    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      const formEl = this as HTMLFormElement;
      const button = formEl.querySelector(
        ".footer-newsletter-btn",
      ) as HTMLButtonElement;
      const emailInput = formEl.querySelector(
        ".footer-newsletter-input",
      ) as HTMLInputElement;

      button.textContent = "...";
      button.disabled = true;

      try {
        const formData = new FormData();
        formData.append("fields[email]", emailInput.value);

        await fetch(formEl.action, {
          method: "POST",
          body: formData,
          mode: "no-cors",
        });

        button.textContent = "Subscribed!";
        emailInput.value = "";
      } catch (err) {
        button.textContent = "Retry";
        button.disabled = false;
      }
    });
  });
</script>
