---
const {
  headline = "Get Weekly Calculator Tips & Guides",
  description = "Join our newsletter for the latest calculators, money-saving tips, and practical guides delivered to your inbox every week.",
  buttonText = "Subscribe Free",
  compact = false,
  dark = false,
} = Astro.props;
---

<div
  class={`newsletter-signup ${compact ? "newsletter-compact" : ""} ${dark ? "newsletter-dark" : ""}`}
>
  <div class="newsletter-content">
    <div class="newsletter-text">
      <h3>{headline}</h3>
      {!compact && <p class="newsletter-description">{description}</p>}
      {
        !compact && (
          <ul class="newsletter-benefits">
            <li>New calculators & guides weekly</li>
            <li>Money-saving tips & tricks</li>
            <li>No spam, unsubscribe anytime</li>
          </ul>
        )
      }
    </div>

    <form
      class="newsletter-form"
      action="https://assets.mailerlite.com/jsonp/2401361/forms/189197513738159323/subscribe"
      method="POST"
      data-newsletter-form
    >
      <div class="newsletter-form-group">
        <input
          type="email"
          name="fields[email]"
          placeholder="your@email.com"
          required
          class="newsletter-input"
          aria-label="Email address"
        />
        <button type="submit" class="btn btn-primary newsletter-btn">
          {buttonText}
        </button>
      </div>
      <p class="newsletter-privacy">
        <small
          >We respect your privacy. Unsubscribe anytime. <a href="/privacy"
            >Privacy Policy</a
          ></small
        >
      </p>
    </form>
  </div>
</div>

<style>
  .newsletter-signup {
    background: linear-gradient(
      135deg,
      var(--color-primary-blue) 0%,
      var(--color-light-blue) 100%
    );
    border-radius: var(--border-radius-lg);
    padding: var(--space-2xl);
    margin: var(--space-2xl) 0;
    box-shadow: var(--shadow-lg);
  }

  .newsletter-dark {
    background: linear-gradient(135deg, #1a2a3a 0%, #2c5f8d 100%);
  }

  .newsletter-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter-text h3 {
    color: #ffffff;
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
  }

  .newsletter-description {
    color: #ffffff;
    opacity: 0.9;
    font-size: var(--text-base);
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .newsletter-benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-xl) 0;
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .newsletter-benefits li {
    color: #ffffff;
    font-size: var(--text-sm);
    opacity: 0.9;
  }

  .newsletter-benefits li::before {
    content: "\2713 ";
    font-weight: bold;
    color: #7defa0;
    padding-right: 0.5rem;
  }

  .newsletter-form-group {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .newsletter-input {
    flex: 1;
    padding: var(--space-md) var(--space-lg);
    border: 2px solid transparent;
    border-radius: var(--border-radius);
    font-size: var(--text-base);
    font-family: var(--font-body);
    background: #ffffff;
    transition: border-color var(--transition-fast);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent-orange);
  }

  .newsletter-btn {
    padding: var(--space-md) var(--space-xl);
    white-space: nowrap;
    flex-shrink: 0;
    font-weight: 700;
  }

  .newsletter-privacy {
    margin: var(--space-sm) 0 0 0;
    text-align: center;
  }

  .newsletter-privacy small {
    color: #ffffff;
    opacity: 0.7;
    font-size: var(--text-xs);
  }

  .newsletter-privacy a {
    color: #ffffff;
    text-decoration: underline;
  }

  /* Compact variant */
  .newsletter-compact {
    padding: var(--space-lg);
    margin: var(--space-lg) 0;
  }

  .newsletter-compact .newsletter-text h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
  }

  /* Success state */
  .newsletter-signup.submitted .newsletter-form-group {
    display: none;
  }

  .newsletter-success {
    color: #ffffff;
    font-size: var(--text-lg);
    font-weight: 600;
    padding: var(--space-md) 0;
  }

  @media (max-width: 640px) {
    .newsletter-form-group {
      flex-direction: column;
    }

    .newsletter-btn {
      width: 100%;
    }

    .newsletter-benefits {
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
    }
  }
</style>

<script>
  document.querySelectorAll("[data-newsletter-form]").forEach((form) => {
    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      const formEl = this as HTMLFormElement;
      const button = formEl.querySelector(
        ".newsletter-btn",
      ) as HTMLButtonElement;
      const emailInput = formEl.querySelector(
        ".newsletter-input",
      ) as HTMLInputElement;
      const email = emailInput.value;

      button.textContent = "Subscribing...";
      button.disabled = true;

      try {
        const formData = new FormData();
        formData.append("fields[email]", email);

        await fetch(formEl.action, {
          method: "POST",
          body: formData,
          mode: "no-cors",
        });

        const container = formEl.closest(".newsletter-signup");
        if (container) {
          container.classList.add("submitted");
          const successEl = document.createElement("p");
          successEl.className = "newsletter-success";
          successEl.textContent =
            "You're subscribed! Check your inbox to confirm.";
          formEl.querySelector(".newsletter-form-group")?.after(successEl);
        }
      } catch (err) {
        button.textContent = "Try Again";
        button.disabled = false;
      }
    });
  });
</script>
