---
import calculatorsData from "../data/calculators.json";

const month = new Date().getMonth();

const seasonalRecommendations = {
  0: ["budget-calculator", "savings-goal-calculator", "retirement-planning-calculator", "fire-calculator"],
  1: ["tax-bracket-calculator", "paycheck-calculator", "debt-to-income-calculator", "credit-card-payoff-calculator"],
  2: ["tax-bracket-calculator", "paycheck-calculator", "refinance-calculator", "home-affordability-calculator"],
  3: ["tax-bracket-calculator", "budget-calculator", "retirement-planning-calculator", "investment-income-goal-calculator"],
  4: ["mortgage-payment-calculator", "home-affordability-calculator", "home-improvement-cost-calculator", "rent-vs-buy-calculator"],
  5: ["home-improvement-cost-calculator", "gas-mileage-calculator", "budget-calculator", "electricity-cost-calculator"],
  6: ["gas-mileage-calculator", "budget-calculator", "tip-calculator", "electricity-cost-calculator"],
  7: ["college-savings-calculator", "student-loan-calculator", "budget-calculator", "gpa-calculator"],
  8: ["college-savings-calculator", "student-loan-calculator", "gpa-calculator", "budget-calculator"],
  9: ["compound-interest-calculator", "savings-goal-calculator", "retirement-planning-calculator", "net-worth-calculator"],
  10: ["budget-calculator", "savings-goal-calculator", "compound-interest-calculator", "fire-calculator"],
  11: ["budget-calculator", "tip-calculator", "savings-goal-calculator", "credit-card-payoff-calculator"],
};

const trendingSlugs = seasonalRecommendations[month] || seasonalRecommendations[0];

const trendingCalcs = trendingSlugs
  .map(slug => calculatorsData.calculators.find(c => c.slug === slug))
  .filter(Boolean);

const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
const currentMonth = monthNames[month];
---

<section class="trending-section">
  <div class="container">
    <div class="section-header text-center">
      <h2>Trending in {currentMonth}</h2>
      <p>Most relevant calculators for this time of year</p>
    </div>

    <div class="trending-grid">
      {trendingCalcs.map((calc, i) => (
        <a href={`/calculators/${calc.slug}`} class="trending-card">
          <span class="trending-rank">#{i + 1}</span>
          <span class="trending-icon">{calc.icon}</span>
          <div class="trending-info">
            <h3>{calc.title}</h3>
            <p>{calc.shortDescription || calc.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .trending-section {
    padding: var(--space-3xl) 0;
  }

  .trending-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .trending-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-white);
    border: 2px solid var(--color-gray);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: all var(--transition-fast);
    position: relative;
  }

  .trending-card:hover {
    border-color: var(--color-accent-orange);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .trending-rank {
    position: absolute;
    top: -8px;
    left: 12px;
    background: var(--color-accent-orange);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 10px;
  }

  .trending-icon {
    font-size: var(--text-3xl);
    flex-shrink: 0;
  }

  .trending-info h3 {
    font-size: var(--text-base);
    color: var(--color-primary-blue);
    margin-bottom: var(--space-xs);
  }

  .trending-info p {
    font-size: var(--text-sm);
    color: var(--color-gray-dark);
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .trending-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
