---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import AdUnit from "../../../components/AdUnit.astro";
import examplesData from "../../../data/examples.json";

export function getStaticPaths() {
  const paths = [];
  for (const [calculatorSlug, calculator] of Object.entries(examplesData)) {
    for (const example of calculator.examples) {
      paths.push({
        params: { slug: `${calculatorSlug}/${example.slug}` },
        props: { example, calculator, calculatorSlug },
      });
    }
  }
  return paths;
}

const { example, calculator, calculatorSlug } = Astro.props;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Calculators", href: "/calculators" },
  { label: calculator.calculatorTitle, href: `/calculators/${calculatorSlug}` },
  { label: "Example", href: null },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": example.title,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${example.description} Result: ${Object.entries(example.result).map(([k, v]) => `${k}: ${v}`).join(', ')}. ${example.insight}`
      }
    }
  ]
};
---

<BaseLayout
  title={example.title}
  description={example.description}
  keywords={`${calculator.calculatorTitle}, ${Object.values(example.inputs).join(', ')}, calculator example`}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <div class="example-page">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />

      <article class="example-content">
        <header class="example-header">
          <h1>{example.title}</h1>
          <p class="example-description">{example.description}</p>
        </header>

        <section class="example-calculation">
          <div class="calc-card inputs-card">
            <h2>Calculation Inputs</h2>
            <dl class="inputs-list">
              {Object.entries(example.inputs).map(([label, value]) => (
                <div class="input-pair">
                  <dt>{label}</dt>
                  <dd>{value}</dd>
                </div>
              ))}
            </dl>
          </div>

          <div class="calc-card results-card">
            <h2>Results</h2>
            <dl class="results-list">
              {Object.entries(example.result).map(([key, value]) => (
                <div class="result-pair">
                  <dt>{key.replace(/([A-Z])/g, ' $1').replace(/^./, s => s.toUpperCase())}</dt>
                  <dd class="result-value">{value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </section>

        <section class="example-insight">
          <h2>What This Means</h2>
          <p>{example.insight}</p>
        </section>

        <section class="example-formula">
          <h2>Formula Used</h2>
          <div class="formula-block">
            <code>{calculator.formula}</code>
          </div>
          <p>{calculator.formulaExplanation}</p>
        </section>

        <div class="cta-section">
          <h2>Try It Yourself</h2>
          <p>Adjust the numbers to match your situation with our free interactive calculator.</p>
          <a href={`/calculators/${calculatorSlug}`} class="btn btn-primary btn-lg">
            Open {calculator.calculatorTitle}
          </a>
        </div>

        <AdUnit slot="4441095467" format="auto" />

        <section class="more-examples">
          <h2>More Examples</h2>
          <div class="examples-grid">
            {calculator.examples
              .filter(ex => ex.slug !== example.slug)
              .map(ex => (
                <a href={`/calculators/examples/${calculatorSlug}/${ex.slug}`} class="example-link-card">
                  <h3>{ex.title}</h3>
                  <p>{ex.description}</p>
                </a>
              ))
            }
          </div>
        </section>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .example-page {
    padding: var(--space-2xl) 0;
  }

  .example-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .example-header {
    margin-bottom: var(--space-2xl);
  }

  .example-header h1 {
    font-size: var(--text-3xl);
    line-height: 1.3;
    margin-bottom: var(--space-md);
  }

  .example-description {
    font-size: var(--text-lg);
    color: var(--color-gray-dark);
    line-height: 1.6;
  }

  .example-calculation {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .calc-card {
    padding: var(--space-xl);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
  }

  .calc-card h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-lg);
  }

  .inputs-card {
    background: var(--color-gray-light);
  }

  .results-card {
    background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
    border: 2px solid var(--color-success);
  }

  .inputs-list,
  .results-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .input-pair,
  .result-pair {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .input-pair:last-child,
  .result-pair:last-child {
    border-bottom: none;
  }

  dt {
    font-weight: 600;
    color: var(--color-gray-dark);
  }

  dd {
    font-weight: 500;
    color: var(--color-primary-blue);
  }

  .result-value {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-success);
  }

  .example-insight {
    background: var(--color-lighter-blue);
    padding: var(--space-xl);
    border-radius: var(--border-radius-lg);
    border-left: 4px solid var(--color-primary-blue);
    margin-bottom: var(--space-2xl);
  }

  .example-insight h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
  }

  .example-insight p {
    line-height: 1.7;
    color: var(--color-gray-dark);
  }

  .example-formula {
    margin-bottom: var(--space-2xl);
  }

  .example-formula h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
  }

  .formula-block {
    background: var(--color-gray-light);
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    margin-bottom: var(--space-md);
    text-align: center;
  }

  .formula-block code {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-primary-blue);
  }

  .example-formula p {
    color: var(--color-gray-dark);
    line-height: 1.6;
  }

  .cta-section {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-gray-light);
    border-radius: var(--border-radius-lg);
    margin-bottom: var(--space-2xl);
  }

  .cta-section h2 {
    margin-bottom: var(--space-sm);
  }

  .cta-section p {
    color: var(--color-gray-dark);
    margin-bottom: var(--space-lg);
  }

  .btn-lg {
    padding: var(--space-md) var(--space-2xl);
    font-size: var(--text-lg);
  }

  .more-examples {
    margin-top: var(--space-2xl);
  }

  .more-examples h2 {
    margin-bottom: var(--space-lg);
  }

  .examples-grid {
    display: grid;
    gap: var(--space-md);
  }

  .example-link-card {
    display: block;
    padding: var(--space-lg);
    background: var(--color-gray-light);
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: all var(--transition-fast);
    border: 2px solid transparent;
  }

  .example-link-card:hover {
    border-color: var(--color-accent-orange);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .example-link-card h3 {
    font-size: var(--text-base);
    color: var(--color-primary-blue);
    margin-bottom: var(--space-xs);
  }

  .example-link-card p {
    font-size: var(--text-sm);
    color: var(--color-gray-dark);
    margin: 0;
  }

  @media (max-width: 768px) {
    .example-calculation {
      grid-template-columns: 1fr;
    }

    .example-header h1 {
      font-size: var(--text-2xl);
    }
  }
</style>
