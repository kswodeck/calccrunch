---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdUnit from "../../components/AdUnit.astro";
import blogPostsData from "../../data/blog-posts.json";

const allContent = import.meta.glob("../../content/blog/*.md", {
  eager: true,
}) as Record<string, { frontmatter?: any }>;

const today = new Date().toISOString().split("T")[0];

// Posts from JSON (existing system)
const jsonPosts = blogPostsData.posts.filter(
  (p) => p.publishDate.split("T")[0] <= today,
);

// Posts from frontmatter (Decap CMS) — exclude any already in JSON
const cmsPosts = Object.values(allContent)
  .filter((mod) => mod.frontmatter?.slug && mod.frontmatter?.publishDate)
  .map((mod) => mod.frontmatter)
  .filter((p) => p.publishDate.split("T")[0] <= today)
  .filter((p) => p.status !== "draft")
  .filter((p) => !jsonPosts.some((jp) => jp.slug === p.slug));

const posts = [...jsonPosts, ...cmsPosts].sort(
  (a, b) =>
    new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime(),
);

const featuredPosts = posts.filter((p) => p.featured);
const recentPosts = posts;

const categories = [...new Set(posts.map((p) => p.category))];
---

<BaseLayout
  title="Blog - Financial Guides, Tips & Calculator Tutorials"
  description="Free guides on personal finance, budgeting, investing, and health. Learn how to calculate mortgage payments, compound interest, BMI, and more with real examples."
  keywords="personal finance blog, calculator guides, how to budget, mortgage guide, compound interest explained, financial planning tips"
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      name: "CalcCrunch Blog",
      description:
        "Free guides on personal finance, budgeting, investing, and health calculations.",
      url: "https://calccrunch.com/blog/",
      publisher: {
        "@type": "Organization",
        name: "CalcCrunch",
        url: "https://calccrunch.com",
      },
    })}
  />

  <div class="blog-page">
    <!-- Hero Section -->
    <section class="blog-hero bg-gradient">
      <div class="container">
        <nav class="breadcrumbs breadcrumbs-light" aria-label="Breadcrumb">
          <ol
            class="breadcrumb-list"
            itemscope
            itemtype="https://schema.org/BreadcrumbList"
          >
            <li
              class="breadcrumb-item"
              itemprop="itemListElement"
              itemscope
              itemtype="https://schema.org/ListItem"
            >
              <a href="/" itemprop="item"><span itemprop="name">Home</span></a>
              <meta itemprop="position" content="1" />
            </li>
            <li
              class="breadcrumb-item"
              itemprop="itemListElement"
              itemscope
              itemtype="https://schema.org/ListItem"
            >
              <span itemprop="name" class="current">Blog</span>
              <meta itemprop="position" content="2" />
            </li>
          </ol>
        </nav>
        <div class="hero-content">
          <h1 class="text-white">CalcCrunch Blog</h1>
          <p class="hero-subtitle text-white">
            Practical guides, real examples, and expert tips to help you make
            smarter financial and health decisions.
          </p>
          <div class="hero-stats">
            <span class="stat">{posts.length} Articles</span>
            <span class="stat">{categories.length} Topics</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Posts -->
    {
      featuredPosts.length > 0 && (
        <section class="featured-section">
          <div class="container">
            <h2 class="section-title">Featured Guides</h2>
            <div class="featured-grid">
              {featuredPosts.slice(0, 3).map((post, i) => (
                <a
                  href={`/blog/${post.slug}`}
                  class={`featured-card ${i === 0 ? "featured-main" : ""}`}
                >
                  <div class="featured-content">
                    <span class="post-category">{post.category}</span>
                    <h3>{post.title}</h3>
                    <p>{post.description}</p>
                    <div class="post-meta">
                      <span class="local-date" data-iso={post.publishDate} />
                      <span>{post.readTime}</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <AdUnit slot="4441095467" format="auto" />

    <!-- All Posts -->
    <section class="all-posts-section">
      <div class="container">
        <h2 class="section-title">All Articles</h2>

        <!-- Category Filter -->
        <div class="category-filter">
          <button class="filter-btn active" data-category="all">All</button>
          {
            categories.map((cat) => (
              <button class="filter-btn" data-category={cat}>
                {cat}
              </button>
            ))
          }
        </div>

        <div class="posts-grid" id="posts-grid">
          {
            recentPosts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="post-card"
                data-category={post.category}
              >
                <div class="post-card-content">
                  <div class="post-card-top">
                    <span class="post-category">{post.category}</span>
                    <span class="post-read-time">{post.readTime}</span>
                  </div>
                  <h3>{post.title}</h3>
                  <p>{post.description}</p>
                  <div class="post-card-footer">
                    <span class="post-date">
                      <span class="local-date" data-iso={post.publishDate} />
                    </span>
                    <div class="post-tags">
                      {post.tags.slice(0, 2).map((tag) => (
                        <span class="mini-tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </a>
            ))
          }
        </div>

        <div class="pagination-controls" id="pagination-controls">
          <p class="posts-count" id="posts-count"></p>
          <button class="btn btn-primary show-more-btn" id="show-more-btn"
            >Show More Articles</button
          >
        </div>
      </div>
    </section>

    <!-- Newsletter/CTA Section -->
    <section class="blog-cta bg-gradient">
      <div class="container text-center">
        <h2 class="text-white">Want More Posts?</h2>
        <p class="text-white">
          We publish new posts and calculator tutorials regularly. Bookmark this
          page or subscribe to our RSS feed to stay updated.
        </p>
        <div class="cta-buttons">
          <a href="/calculators" class="btn btn-secondary"
            >Explore Calculators</a
          >
          <a href="/write-for-us" class="btn btn-outline-light">Write for Us</a>
          <a href="/rss.xml" class="btn btn-outline-light">RSS Feed</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const POSTS_PER_PAGE = 10;
    const filterBtns = document.querySelectorAll(".filter-btn");
    const allCards = Array.from(
      document.querySelectorAll(".post-card"),
    ) as HTMLElement[];
    const showMoreBtn = document.getElementById("show-more-btn") as HTMLElement;
    const postsCount = document.getElementById("posts-count") as HTMLElement;

    let currentCategory = "all";
    let visibleCount = POSTS_PER_PAGE;

    function getFilteredCards(): HTMLElement[] {
      if (currentCategory === "all") return allCards;
      return allCards.filter(
        (card) => card.dataset.category === currentCategory,
      );
    }

    function render() {
      const filtered = getFilteredCards();
      const total = filtered.length;
      const showing = Math.min(visibleCount, total);

      allCards.forEach((card) => {
        card.style.display = "none";
      });
      filtered.slice(0, visibleCount).forEach((card) => {
        card.style.display = "";
      });

      postsCount.textContent = `Showing ${showing} of ${total} article${total !== 1 ? "s" : ""}`;

      if (showing >= total) {
        showMoreBtn.style.display = "none";
      } else {
        showMoreBtn.style.display = "";
        showMoreBtn.textContent = `Show More (${total - showing} remaining)`;
      }
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        currentCategory = (btn as HTMLElement).dataset.category || "all";
        filterBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        visibleCount = POSTS_PER_PAGE;
        render();
      });
    });

    showMoreBtn.addEventListener("click", () => {
      visibleCount += POSTS_PER_PAGE;
      render();
    });

    render();

    document.querySelectorAll(".local-date").forEach((el) => {
      const iso = el.getAttribute("data-iso");
      if (iso) {
        const [year, month, day] = iso.split("T")[0].split("-").map(Number);
        const date = new Date(year, month - 1, day);
        el.textContent = date.toLocaleDateString("en-US", {
          month: "short",
          day: "numeric",
          year: "numeric",
        });
      }
    });
  });
</script>

<style>
  .blog-page {
    background: var(--color-white);
  }

  /* Light breadcrumbs for dark backgrounds */
  .breadcrumbs-light {
    padding: var(--space-lg) 0;
    margin-bottom: var(--space-lg);
  }

  .breadcrumbs-light .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: var(--space-sm);
  }

  .breadcrumbs-light .breadcrumb-item {
    display: flex;
    align-items: center;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.9);
  }

  .breadcrumbs-light .breadcrumb-item:not(:last-child)::after {
    content: "›";
    margin-left: var(--space-sm);
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--text-lg);
  }

  .breadcrumbs-light .breadcrumb-item a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .breadcrumbs-light .breadcrumb-item a:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  .breadcrumbs-light .breadcrumb-item .current {
    color: #ffffff;
    font-weight: 600;
  }

  /* Hero */
  .blog-hero {
    padding: var(--space-3xl) 0;
  }

  .blog-hero .hero-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .blog-hero h1 {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-md);
  }

  .hero-subtitle {
    font-size: var(--text-xl);
    opacity: 0.95;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-2xl);
  }

  .hero-stats .stat {
    font-weight: 600;
    font-size: var(--text-base);
    opacity: 0.9;
    color: white;
  }

  /* Section Title */
  .section-title {
    font-size: var(--text-3xl);
    color: var(--color-primary-blue);
    margin-bottom: var(--space-xl);
  }

  /* Featured Section */
  .featured-section {
    padding: var(--space-3xl) 0;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-lg);
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-2xl);
    background: #f5f5f5;
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    border: 2px solid transparent;
  }

  .featured-card.featured-main {
    grid-row: span 2;
    background: linear-gradient(135deg, #e8f4f8 0%, #f0f8ff 100%);
    border-color: #5a9fd4;
  }

  .featured-card:hover {
    border-color: var(--color-accent-orange);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .featured-content {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent-orange);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: var(--space-md);
  }

  .featured-card h3 {
    font-size: var(--text-xl);
    color: #1a3a5c;
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .featured-card.featured-main h3 {
    font-size: var(--text-2xl);
  }

  .featured-card p {
    color: #3a3a3a;
    line-height: 1.6;
    flex: 1;
    font-size: var(--text-base);
  }

  .post-meta {
    display: flex;
    gap: var(--space-lg);
    font-size: var(--text-sm);
    color: #555555;
    margin-top: var(--space-lg);
  }

  /* Category Filter */
  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
  }

  .filter-btn {
    padding: var(--space-sm) var(--space-lg);
    border: 2px solid var(--color-gray);
    border-radius: 20px;
    background: transparent;
    color: var(--color-gray-dark);
    font-weight: 600;
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    border-color: var(--color-accent-orange);
    color: var(--color-accent-orange);
  }

  .filter-btn.active {
    background: var(--color-primary-blue);
    border-color: var(--color-primary-blue);
    color: white;
  }

  /* Posts Grid */
  .all-posts-section {
    padding: var(--space-3xl) 0;
    background: var(--color-gray-light);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    border: 2px solid transparent;
    overflow: hidden;
  }

  .post-card:hover {
    border-color: var(--color-accent-orange);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .post-card-content {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .post-read-time {
    font-size: var(--text-xs);
    color: var(--color-gray-dark);
    opacity: 0.7;
  }

  .post-card h3 {
    font-size: var(--text-lg);
    color: var(--color-primary-blue);
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .post-card p {
    color: var(--color-gray-dark);
    font-size: var(--text-sm);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .post-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-gray);
  }

  .post-date {
    font-size: var(--text-xs);
    color: var(--color-gray-dark);
    opacity: 0.7;
  }

  .post-tags {
    display: flex;
    gap: var(--space-xs);
  }

  .mini-tag {
    font-size: 10px;
    padding: 2px 6px;
    background: var(--color-gray-light);
    border-radius: 3px;
    color: var(--color-gray-dark);
  }

  /* Pagination Controls */
  .pagination-controls {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
  }

  .posts-count {
    font-size: var(--text-sm);
    color: var(--color-gray-dark);
    margin: 0;
  }

  .show-more-btn {
    padding: var(--space-sm) var(--space-2xl);
  }

  /* Blog CTA */
  .blog-cta {
    padding: var(--space-3xl) 0;
  }

  .blog-cta h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
  }

  .blog-cta p {
    font-size: var(--text-xl);
    margin-bottom: var(--space-xl);
    opacity: 0.95;
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-outline-light {
    border: 2px solid white;
    color: white;
    background: transparent;
    padding: var(--space-sm) var(--space-xl);
    border-radius: var(--border-radius);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .btn-outline-light:hover {
    background: white;
    color: var(--color-primary-blue);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .blog-hero h1 {
      font-size: var(--text-4xl);
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }

    .featured-card.featured-main {
      grid-row: span 1;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .hero-stats {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
