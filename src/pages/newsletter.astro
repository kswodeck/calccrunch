---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
---

<BaseLayout
  title="Newsletter - Free Weekly Calculator Tips & Financial Guides"
  description="Subscribe to the CalcCrunch newsletter for weekly calculator tips, money-saving guides, and practical financial advice. Free, no spam, unsubscribe anytime."
  keywords="calculator newsletter, financial tips newsletter, money saving tips, weekly finance guide"
>
  <div class="newsletter-page">
    <section class="newsletter-hero bg-gradient">
      <div class="container">
        <div class="hero-content">
          <h1 class="text-white">The CalcCrunch Newsletter</h1>
          <p class="hero-subtitle text-white">
            Get smarter with your money, health, and time — one email per week.
          </p>
        </div>
      </div>
    </section>

    <section class="newsletter-main">
      <div class="container">
        <div class="newsletter-grid">
          <div class="newsletter-info">
            <h2>What You'll Get</h2>
            <div class="benefit-cards">
              <div class="benefit-card">
                <span class="benefit-icon">&#128200;</span>
                <h3>New Calculators</h3>
                <p>
                  Be the first to know when we launch new free tools and
                  calculators.
                </p>
              </div>
              <div class="benefit-card">
                <span class="benefit-icon">&#128161;</span>
                <h3>Practical Tips</h3>
                <p>
                  Actionable advice on budgeting, saving, investing, and health
                  tracking.
                </p>
              </div>
              <div class="benefit-card">
                <span class="benefit-icon">&#128218;</span>
                <h3>In-Depth Guides</h3>
                <p>
                  Our latest blog posts with real-world examples and
                  step-by-step walkthroughs.
                </p>
              </div>
              <div class="benefit-card">
                <span class="benefit-icon">&#127919;</span>
                <h3>Quick Wins</h3>
                <p>
                  Simple changes that save you time and money — delivered
                  weekly.
                </p>
              </div>
            </div>

            <div class="newsletter-promise">
              <h3>Our Promise</h3>
              <ul>
                <li>One email per week, max</li>
                <li>No spam, no selling your data</li>
                <li>Unsubscribe with one click, anytime</li>
                <li>100% free, forever</li>
              </ul>
            </div>
          </div>

          <div class="newsletter-form-section">
            <div class="form-card">
              <NewsletterSignup
                headline="Subscribe Now"
                description="Join and get smarter about your numbers."
                buttonText="Subscribe Free"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .newsletter-page {
    background: var(--color-white);
  }

  .newsletter-hero {
    padding: var(--space-3xl) 0;
    text-align: center;
  }

  .newsletter-hero h1 {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-md);
  }

  .hero-subtitle {
    font-size: var(--text-xl);
    opacity: 0.95;
    max-width: 600px;
    margin: 0 auto;
  }

  .newsletter-main {
    padding: var(--space-3xl) 0;
  }

  .newsletter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .newsletter-info h2 {
    font-size: var(--text-3xl);
    color: var(--color-primary-blue);
    margin-bottom: var(--space-xl);
  }

  .benefit-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .benefit-card {
    background: var(--color-gray-light);
    padding: var(--space-lg);
    border-radius: var(--border-radius-lg);
    text-align: center;
  }

  .benefit-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .benefit-card h3 {
    color: var(--color-primary-blue);
    font-size: var(--text-base);
    margin-bottom: var(--space-xs);
  }

  .benefit-card p {
    color: var(--color-gray-dark);
    font-size: var(--text-sm);
    line-height: 1.5;
    margin: 0;
  }

  .newsletter-promise {
    background: var(--color-lighter-blue);
    padding: var(--space-xl);
    border-radius: var(--border-radius-lg);
    border-left: 4px solid var(--color-primary-blue);
  }

  .newsletter-promise h3 {
    color: var(--color-primary-blue);
    margin-bottom: var(--space-md);
  }

  .newsletter-promise ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .newsletter-promise li {
    color: var(--color-gray-dark);
    padding: var(--space-xs) 0;
    font-size: var(--text-sm);
  }

  .newsletter-promise li::before {
    content: "\2713 ";
    color: var(--color-primary-blue);
    font-weight: bold;
    padding-right: 0.5rem;
  }

  .form-card {
    position: sticky;
    top: 100px;
  }

  @media (max-width: 768px) {
    .newsletter-grid {
      grid-template-columns: 1fr;
    }

    .benefit-cards {
      grid-template-columns: 1fr;
    }

    .newsletter-hero h1 {
      font-size: var(--text-3xl);
    }

    .form-card {
      position: static;
    }
  }
</style>
