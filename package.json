{
  "name": "calccrunch",
  "type": "module",
  "version": "1.0.1",
  "scripts": {
    "dev": "npm run update-counts && astro dev",
    "build": "npm run clean && npm run update-counts && astro build",
    "preview": "astro preview",
    "analyze": "npm run build && npx lighthouse https://calccrunch.com --output html --view",
    "update-counts": "node src/scripts/update-category-counts.js",
    "astro": "astro",
    "clean": "rm -rf dist .astro node_modules/.vite",
    "check": "astro check --no-types"
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.9",
    "astro": "^6.3.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2"
  }
}
